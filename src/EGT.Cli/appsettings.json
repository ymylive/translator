{
  "PipelineDefaults": {
    "ProviderName": "llm",
    "FallbackProviderName": "llm",
    "SourceLang": "auto",
    "TargetLang": "zh-Hans",
    "MaxConcurrency": 1,
    "ChunkSentenceCount": 8,
    "MaxItemsPerBatch": 8,
    "MaxCharsPerBatch": 1600,
    "AiBatchSize": 4,
    "MaxFileSizeMb": 50,
    "OutputRoot": "EGT_Output",
    "BackupRoot": "EGT_Backup",
    "CacheFilePath": "EGT_Cache/translation_cache.db"
  },
  "Plugins": {
    "Directory": "Plugins"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/egt-cli-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
