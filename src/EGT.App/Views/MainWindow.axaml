<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EGT.App.ViewModels"
        x:Class="EGT.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1160"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Title="easy_game_translator (EGT)">
  <Grid RowDefinitions="Auto,*,Auto" Margin="22">
    <Border Grid.Row="0" Classes="card">
      <StackPanel Spacing="8">
        <TextBlock Text="easy_game_translator (EGT)"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#0F766E" />
        <TextBlock Text="将游戏 EXE 拖入下方区域后开始翻译。默认仅上传抽取出的文本片段，不上传游戏文件。"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="1.2*,1*" MinHeight="0">
      <ScrollViewer Grid.Column="0"
                    MinHeight="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Margin="0,0,6,0">
          <Border Name="DropZone"
                  Classes="card"
                  Height="160"
                  BorderBrush="#14B8A6"
                  BorderThickness="2"
                  CornerRadius="16"
                  PointerPressed="DropZone_OnPointerPressed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
              <TextBlock Text="第 1 步：将 .exe 拖到这里"
                         FontWeight="SemiBold"
                         FontSize="20"
                         HorizontalAlignment="Center" />
              <TextBlock Text="也可以点击此区域并粘贴 EXE 绝对路径。"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Text="快速开始（必填）" Classes="section-title" />
              <TextBlock Text="请先填写这些字段。高级设置可选。"
                         TextWrapping="Wrap" />
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    ColumnDefinitions="130,*">
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="EXE 路径" />
                <TextBox Grid.Row="0" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ExePath}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="处理策略" />
                <TextBox Grid.Row="1" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProfileName}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="翻译引擎" />
                <ComboBox Grid.Row="2"
                          Grid.Column="1"
                          Classes="form-field"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding ProviderOptions}"
                          SelectedItem="{Binding ProviderName}" />

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="源语言" />
                <TextBox Grid.Row="3" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding SourceLang}" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="目标语言" />
                <TextBox Grid.Row="4" Grid.Column="1" Classes="form-field" Text="{Binding TargetLang}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="高级设置" Classes="section-title" />
                <Button Content="{Binding AdvancedToggleText}" Command="{Binding ToggleAdvancedCommand}" />
                <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" />
              </StackPanel>
              <TextBlock IsVisible="{Binding ShowAdvancedSettings}"
                         Text="用于术语表、私有接口、分块和性能调优。"
                         TextWrapping="Wrap" />
              <Grid IsVisible="{Binding ShowAdvancedSettings}"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                    ColumnDefinitions="130,*">
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="术语表 CSV" />
                <TextBox Grid.Row="0" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding GlossaryPath}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="API Key" />
                <TextBox Grid.Row="1" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProviderApiKey}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Base URL" />
                <TextBox Grid.Row="2" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProviderEndpoint}" />

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="模型" />
                <TextBox Grid.Row="3" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProviderModel}" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="区域" />
                <TextBox Grid.Row="4" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProviderRegion}" />

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="AI 优先级1" />
                <ComboBox Grid.Row="5"
                          Grid.Column="1"
                          Classes="form-field"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding AiPriorityOptions}"
                          SelectedItem="{Binding AiPriorityPrimary}" />

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="AI 优先级2" />
                <ComboBox Grid.Row="6"
                          Grid.Column="1"
                          Classes="form-field"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding AiPriorityOptions}"
                          SelectedItem="{Binding AiPrioritySecondary}" />

                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="AI 优先级3" />
                <ComboBox Grid.Row="7"
                          Grid.Column="1"
                          Classes="form-field"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding AiPriorityOptions}"
                          SelectedItem="{Binding AiPriorityTertiary}" />

                <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退1引擎" />
                <TextBox Grid.Row="8" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderName}" />

                <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退1 API Key" />
                <TextBox Grid.Row="9" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderApiKey}" />

                <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退1 Base URL" />
                <TextBox Grid.Row="10" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderEndpoint}" />

                <TextBlock Grid.Row="11" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退1模型" />
                <TextBox Grid.Row="11" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderModel}" />

                <TextBlock Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退1区域" />
                <TextBox Grid.Row="12" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderRegion}" />

                <TextBlock Grid.Row="13" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退2引擎" />
                <TextBox Grid.Row="13" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding SecondFallbackProviderName}" />

                <TextBlock Grid.Row="14" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退2 API Key" />
                <TextBox Grid.Row="14" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding SecondFallbackProviderApiKey}" />

                <TextBlock Grid.Row="15" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退2 Base URL" />
                <TextBox Grid.Row="15" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding SecondFallbackProviderEndpoint}" />

                <TextBlock Grid.Row="16" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退2模型" />
                <TextBox Grid.Row="16" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding SecondFallbackProviderModel}" />

                <TextBlock Grid.Row="17" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="回退2区域" />
                <TextBox Grid.Row="17" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding SecondFallbackProviderRegion}" />

                <TextBlock Grid.Row="18" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="并发数" />
                <TextBox Grid.Row="18" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding MaxConcurrency}" />

                <TextBlock Grid.Row="19" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="AI 单次句数" />
                <TextBox Grid.Row="19" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding AiBatchSize}" />

                <TextBlock Grid.Row="20" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="分块句数 / 字符上限 / 文件MB上限" />
                <StackPanel Grid.Row="20" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                  <TextBox Width="120" Classes="form-field" Text="{Binding MaxItemsPerBatch}" />
                  <TextBox Width="160" Classes="form-field" Text="{Binding MaxCharsPerBatch}" />
                  <TextBox Width="120" Classes="form-field" Text="{Binding MaxFileSizeMb}" />
                </StackPanel>

                <CheckBox Grid.Row="21"
                          Grid.Column="1"
                          Classes="form-field"
                          IsChecked="{Binding ApplyInPlace}"
                          Content="直接写回游戏目录（会先备份）" />
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" MinHeight="0" Margin="12,0,0,0">
        <Border Grid.Row="0"
                Classes="card"
                BorderBrush="{Binding StatusBorderBrush}"
                Background="{Binding StatusBackground}">
          <StackPanel Spacing="10">
            <TextBlock Text="执行状态" Classes="section-title" />
            <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusDetail}" TextWrapping="Wrap" />

            <Border IsVisible="{Binding HasError}"
                    Background="#FEF2F2"
                    BorderBrush="#FCA5A5"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10">
              <TextBlock Text="{Binding ErrorMessage}"
                         Foreground="#B91C1C"
                         TextWrapping="Wrap" />
            </Border>

            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="18" />
            <TextBlock Text="{Binding ProgressCaption}" />
            <TextBlock Text="{Binding CurrentFileCaption}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Classes="primary" Content="开始" Command="{Binding StartCommand}" />
              <Button Classes="accent" Content="取消" Command="{Binding CancelCommand}" />
              <Button Content="打开输出目录" Command="{Binding OpenOutputCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="card" Margin="0,12,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="翻译质量" Classes="section-title" />
            <TextBlock Text="{Binding QualitySummary}" TextWrapping="Wrap" />
            <TextBox Text="{Binding QualityPreview}"
                     MinHeight="120"
                     FontFamily="Consolas, Cascadia Mono, Menlo"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Content="打开质量报告(JSON)" Command="{Binding OpenQualityReportCommand}" />
              <Button Content="打开翻译预览(CSV)" Command="{Binding OpenPreviewCommand}" />
              <Button Content="打开失败明细(CSV)" Command="{Binding OpenFailedItemsCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Grid.Row="2" Classes="card" MinHeight="0" Margin="0,12,0,0">
          <Grid RowDefinitions="Auto,*" MinHeight="0">
            <TextBlock Grid.Row="0" Text="日志（可复制）" Classes="section-title" Margin="0,0,0,8" />
            <TextBox Name="LogsTextBox"
                     Grid.Row="1"
                     MinHeight="160"
                     Text="{Binding Logs}"
                     FontFamily="Consolas, Cascadia Mono, Menlo"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Classes="card" Margin="0,12,0,0" Padding="12">
      <TextBlock Text="{Binding OutputPath, StringFormat='输出目录：{0}'}" />
    </Border>
  </Grid>
</Window>
