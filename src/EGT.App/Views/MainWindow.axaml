<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EGT.App.ViewModels"
        x:Class="EGT.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1160"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Title="easy_game_translator (EGT)">
  <Grid RowDefinitions="Auto,*,Auto" Margin="22">
    <Border Grid.Row="0" Classes="card">
      <StackPanel Spacing="8">
        <TextBlock Text="easy_game_translator (EGT)"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#0F766E" />
        <TextBlock Text="Drag a game EXE into the drop zone, then run translation. By default EGT sends only extracted text snippets."
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="1.2*,1*" MinHeight="0">
      <ScrollViewer Grid.Column="0"
                    MinHeight="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Margin="0,0,6,0">
          <Border Name="DropZone"
                  Classes="card"
                  Height="160"
                  BorderBrush="#14B8A6"
                  BorderThickness="2"
                  CornerRadius="16"
                  PointerPressed="DropZone_OnPointerPressed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
              <TextBlock Text="Step 1: Drop .exe here"
                         FontWeight="SemiBold"
                         FontSize="20"
                         HorizontalAlignment="Center" />
              <TextBlock Text="You can also paste an absolute path by clicking this area."
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Text="Quick Start (Required)" Classes="section-title" />
              <TextBlock Text="Fill these fields first. Advanced settings are optional."
                         TextWrapping="Wrap" />
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    ColumnDefinitions="130,*">
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="EXE Path" />
                <TextBox Grid.Row="0" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ExePath}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Profile" />
                <TextBox Grid.Row="1" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProfileName}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Provider" />
                <ComboBox Grid.Row="2"
                          Grid.Column="1"
                          Classes="form-field"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding ProviderOptions}"
                          SelectedItem="{Binding ProviderName}" />

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Source Lang" />
                <TextBox Grid.Row="3" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding SourceLang}" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Target Lang" />
                <TextBox Grid.Row="4" Grid.Column="1" Classes="form-field" Text="{Binding TargetLang}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Advanced Settings" Classes="section-title" />
                <Button Content="{Binding AdvancedToggleText}" Command="{Binding ToggleAdvancedCommand}" />
              </StackPanel>
              <TextBlock IsVisible="{Binding ShowAdvancedSettings}"
                         Text="Use these options for glossary, private endpoints, and performance tuning."
                         TextWrapping="Wrap" />
              <Grid IsVisible="{Binding ShowAdvancedSettings}"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                    ColumnDefinitions="130,*">
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Glossary CSV" />
                <TextBox Grid.Row="0" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding GlossaryPath}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="API Key" />
                <TextBox Grid.Row="1" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProviderApiKey}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Base URL" />
                <TextBox Grid.Row="2" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProviderEndpoint}" />

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Model" />
                <TextBox Grid.Row="3" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProviderModel}" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Region" />
                <TextBox Grid.Row="4" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding ProviderRegion}" />

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Fallback Provider" />
                <TextBox Grid.Row="5" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderName}" />

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Fallback API Key" />
                <TextBox Grid.Row="6" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderApiKey}" />

                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Fallback Base URL" />
                <TextBox Grid.Row="7" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderEndpoint}" />

                <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Fallback Model" />
                <TextBox Grid.Row="8" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderModel}" />

                <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Fallback Region" />
                <TextBox Grid.Row="9" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding FallbackProviderRegion}" />

                <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Concurrency" />
                <TextBox Grid.Row="10" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding MaxConcurrency}" />

                <TextBlock Grid.Row="11" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="AI Batch Size" />
                <TextBox Grid.Row="11" Grid.Column="1" Classes="form-field" Margin="0,0,0,8" Text="{Binding AiBatchSize}" />

                <TextBlock Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Batch Items / Chars" />
                <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                  <TextBox Width="120" Classes="form-field" Text="{Binding MaxItemsPerBatch}" />
                  <TextBox Width="160" Classes="form-field" Text="{Binding MaxCharsPerBatch}" />
                  <TextBox Width="120" Classes="form-field" Text="{Binding MaxFileSizeMb}" />
                </StackPanel>

                <CheckBox Grid.Row="13"
                          Grid.Column="1"
                          Classes="form-field"
                          IsChecked="{Binding ApplyInPlace}"
                          Content="Apply directly to game folder (backup first)" />
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Grid Grid.Column="1" RowDefinitions="Auto,*" MinHeight="0" Margin="12,0,0,0">
        <Border Grid.Row="0"
                Classes="card"
                BorderBrush="{Binding StatusBorderBrush}"
                Background="{Binding StatusBackground}">
          <StackPanel Spacing="10">
            <TextBlock Text="Execution Status" Classes="section-title" />
            <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusDetail}" TextWrapping="Wrap" />

            <Border IsVisible="{Binding HasError}"
                    Background="#FEF2F2"
                    BorderBrush="#FCA5A5"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10">
              <TextBlock Text="{Binding ErrorMessage}"
                         Foreground="#B91C1C"
                         TextWrapping="Wrap" />
            </Border>

            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="18" />
            <TextBlock Text="{Binding ProgressCaption}" />
            <TextBlock Text="{Binding CurrentFileCaption}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Classes="primary" Content="Start" Command="{Binding StartCommand}" />
              <Button Classes="accent" Content="Cancel" Command="{Binding CancelCommand}" />
              <Button Content="Open Output" Command="{Binding OpenOutputCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="card" MinHeight="0" Margin="0,12,0,0">
          <Grid RowDefinitions="Auto,*" MinHeight="0">
            <TextBlock Grid.Row="0" Text="Logs (copyable)" Classes="section-title" Margin="0,0,0,8" />
            <TextBox Grid.Row="1"
                     MinHeight="160"
                     Text="{Binding Logs}"
                     FontFamily="Consolas, Cascadia Mono, Menlo"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Classes="card" Margin="0,12,0,0" Padding="12">
      <TextBlock Text="{Binding OutputPath, StringFormat='Output directory: {0}'}" />
    </Border>
  </Grid>
</Window>
