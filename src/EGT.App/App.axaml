<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EGT.App.App"
             RequestedThemeVariant="Light">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI" />
      <Setter Property="Foreground" Value="#042F2E" />
    </Style>

    <Style Selector="Button">
      <Setter Property="Height" Value="44" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#134E4A" />
      <Setter Property="BorderBrush" Value="#0F766E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
          <BrushTransition Property="Background" Duration="0:0:0.18" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0F766E" />
      <Setter Property="BorderBrush" Value="#115E59" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#C2410C" />
      <Setter Property="BorderBrush" Value="#9A3412" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#CCFBF1" />
      <Setter Property="Opacity" Value="0.96" />
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="#99F6E4" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button:focus">
      <Setter Property="BorderBrush" Value="#0F172A" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="TextBox.form-field">
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#042F2E" />
      <Setter Property="BorderBrush" Value="#14B8A6" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBox.form-field:pointerover">
      <Setter Property="BorderBrush" Value="#0F766E" />
    </Style>

    <Style Selector="TextBox.form-field:focus">
      <Setter Property="BorderBrush" Value="#0F172A" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="ComboBox.form-field">
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#042F2E" />
      <Setter Property="BorderBrush" Value="#14B8A6" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="ComboBox.form-field:pointerover">
      <Setter Property="BorderBrush" Value="#0F766E" />
    </Style>

    <Style Selector="ComboBox.form-field:focus">
      <Setter Property="BorderBrush" Value="#0F172A" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="CheckBox.form-field">
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Foreground" Value="#042F2E" />
    </Style>

    <Style Selector="CheckBox.form-field:focus">
      <Setter Property="Foreground" Value="#0F172A" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="White" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#99CCFBF1" />
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Foreground" Value="#0F766E" />
    </Style>
  </Application.Styles>
</Application>
