{
    "PipelineDefaults":  {
                             "ProviderName":  "llm",
                             "FallbackProviderName":  "llm",
                             "SourceLang":  "auto",
                             "TargetLang":  "zh-Hans",
                             "MaxConcurrency":  6,
                             "ChunkSentenceCount":  16,
                             "MaxItemsPerBatch":  16,
                             "MaxCharsPerBatch":  6000,
                             "AiBatchSize":  12,
                             "MaxFileSizeMb":  50,
                             "OutputRoot":  "EGT_Output",
                             "BackupRoot":  "EGT_Backup",
                             "CacheFilePath":  "EGT_Cache/translation_cache.db",
                             "AiPriorityPrimary":  "openai-responses",
                             "AiPrioritySecondary":  "manual",
                             "AiPriorityTertiary":  "none"
                         },
    "Plugins":  {
                    "Directory":  "Plugins"
                },
    "Serilog":  {
                    "Using":  [
                                  "Serilog.Sinks.File"
                              ],
                    "MinimumLevel":  "Information",
                    "WriteTo":  [
                                    {
                                        "Name":  "File",
                                        "Args":  {
                                                     "path":  "logs/egt-app-.log",
                                                     "rollingInterval":  "Day"
                                                 }
                                    }
                                ]
                }
}
